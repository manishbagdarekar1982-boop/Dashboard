# ── SSH Tunnel to AWS EC2 ──────────────────────────────────────────
# The backend opens an SSH tunnel to reach PostgreSQL on the EC2 instance.
# Get the .pem key file from the project admin.
SSH_HOST=your-ec2-ip            # EC2 public IP
SSH_PORT=22
SSH_USER=ubuntu
SSH_KEY_PATH=/path/to/your-key.pem
SSH_LOCAL_PORT=5435              # local port forwarded to remote Postgres (avoid 5432/5433 if PgAdmin uses them)

# ── Remote PostgreSQL (accessed via SSH tunnel) ──────────────────
DB_HOST=127.0.0.1
DB_PORT=5435                    # must match SSH_LOCAL_PORT
DB_NAME=local_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── App Config ────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change-this-in-production
